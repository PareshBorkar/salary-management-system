APP_NAME=salary-management-api
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3000/v1
