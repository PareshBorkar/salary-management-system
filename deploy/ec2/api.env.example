APP_NAME=salary-management-api
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=https://your-frontend-domain.example
DATABASE_URL=postgresql://salary:replace-with-strong-password@postgres:5432/salary_management?schema=public
REDIS_URL=redis://redis:6379
RATE_LIMIT_ENABLED=true
RATE_LIMIT_BUCKET_CAPACITY=1000
RATE_LIMIT_REFILL_TOKENS=1000
RATE_LIMIT_REFILL_INTERVAL_MS=60000
JWT_SECRET=replace-with-a-long-random-secret
